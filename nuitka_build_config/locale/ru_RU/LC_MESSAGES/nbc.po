#: nuitka_build_config/generator.py:23
#: nuitka_build_config/models/__init__.py:35
msgid ""
"Compilation mode: 'accelerated' (with Python dependency), 'standalone' "
"(folder with exe), 'onefile' (single exe), 'module' (extension module), "
"'app' (onefile for macOS with .app), 'app-dist' (standalone for macOS "
"with .app), 'package' (package as module), 'dll' (experimental)"
msgstr ""
"Режим компиляции: 'accelerated' (с зависимостью от Python), 'standalone' "
"(папка с exe), 'onefile' (один exe-файл), 'module' (модуль расширения), "
"'app' (один файл для macOS с .app), 'app-dist' (автономный для macOS "
"с .app), 'package' (пакет как модуль), 'dll' (экспериментальный)"

#: nuitka_build_config/generator.py:27
#: nuitka_build_config/models/__init__.py:42
msgid "Run the compiled binary immediately after compilation (--run)"
msgstr "Запустить скомпилированный бинарный файл сразу после компиляции (--run)"

#: nuitka_build_config/generator.py:31
msgid "Follow all imported modules. In standalone mode defaults to True"
msgstr "Следовать за всеми импортированными модулями. В автономном режиме по умолчанию включено"

#: nuitka_build_config/generator.py:33
msgid "DO NOT follow all imported modules"
msgstr "НЕ следовать за всеми импортированными модулями"

#: nuitka_build_config/generator.py:36
msgid "Follow into the specified modules/packages. Example: 'requests', 'numpy'"
msgstr "Следовать в указанные модули/пакеты. Пример: 'requests', 'numpy'"

#: nuitka_build_config/generator.py:38
msgid ""
"DO NOT follow into the specified modules/packages. Supports patterns, "
"e.g. '*.tests'"
msgstr ""
"НЕ следовать в указанные модули/пакеты. Поддерживает шаблоны, "
"например '*.tests'"

#: nuitka_build_config/generator.py:40
msgid "List of plugins to enable. Example: 'tk-inter', 'anti-bloat'"
msgstr "Список включаемых плагинов. Пример: 'tk-inter', 'anti-bloat'"

#: nuitka_build_config/generator.py:42
msgid "List of plugins to disable"
msgstr "Список отключаемых плагинов"

#: nuitka_build_config/generator.py:44
#: nuitka_build_config/models/__init__.py:77
msgid "Main file to compile (alternative to positional argument --main)"
msgstr "Главный файл для компиляции (альтернатива позиционному аргументу --main)"

#: nuitka_build_config/generator.py:46
msgid "Main file to compile (positional argument)"
msgstr "Главный файл для компиляции (позиционный аргумент)"

#: nuitka_build_config/generator.py:48
#: nuitka_build_config/models/__init__.py:102
msgid ""
"Python flags: '-S' (no_site), '-O' (no_asserts), 'no_warnings', "
"'no_docstrings', '-u' (unbuffered)"
msgstr ""
"Флаги Python: '-S' (no_site), '-O' (no_asserts), 'no_warnings', "
"'no_docstrings', '-u' (небуферизованный)"

#: nuitka_build_config/generator.py:50
#: nuitka_build_config/models/__init__.py:107
msgid ""
"Number of parallel compilation jobs. Negative values = CPU cores minus "
"value (--jobs)"
msgstr ""
"Количество параллельных задач компиляции. Отрицательные значения = ядра "
"ЦП минус значение (--jobs)"

#: nuitka_build_config/generator.py:52
#: nuitka_build_config/models/__init__.py:112
msgid "Enable debug mode: self-checks, additional checks (--debug)"
msgstr "Включить режим отладки: самопроверки, дополнительные проверки (--debug)"

#: nuitka_build_config/generator.py:54
#: nuitka_build_config/models/__init__.py:117
msgid "Create an XML compilation report (--report)"
msgstr "Создать XML-отчёт о компиляции (--report)"

#: nuitka_build_config/generator.py:56
#: nuitka_build_config/models/__init__.py:122
msgid "Directory for output files (build, dist, binaries) (--output-dir)"
msgstr "Каталог для выходных файлов (build, dist, бинарные файлы) (--output-dir)"

#: nuitka_build_config/generator.py:58
#: nuitka_build_config/models/__init__.py:127
msgid ""
"Name of the output executable. For onefile may include path (--output-"
"filename)"
msgstr ""
"Имя выходного исполняемого файла. Для onefile может включать путь (--output-"
"filename)"

#: nuitka_build_config/generator.py:60
#: nuitka_build_config/models/__init__.py:132
msgid "Remove the build directory after creating the binary (--remove-output)"
msgstr "Удалить каталог сборки после создания бинарного файла (--remove-output)"

#: nuitka_build_config/generator.py:64
msgid "Console output verbosity level: verbose"
msgstr "Уровень подробности вывода в консоль: подробный"

#: nuitka_build_config/generator.py:66
msgid "Console output verbosity level: quiet"
msgstr "Уровень подробности вывода в консоль: тихий"

#: nuitka_build_config/generator.py:71
#: nuitka_build_config/models/__init__.py:47
msgid "Settings for including additional modules, packages and data files"
msgstr "Настройки для включения дополнительных модулей, пакетов и файлов данных"

#: nuitka_build_config/generator.py:73
#: nuitka_build_config/models/__init__.py:13
msgid "List of packages to include in the build (--include-package)"
msgstr "Список пакетов для включения в сборку (--include-package)"

#: nuitka_build_config/generator.py:75
#: nuitka_build_config/models/__init__.py:15
msgid "List of modules to include in the build (--include-module)"
msgstr "Список модулей для включения в сборку (--include-module)"

#: nuitka_build_config/generator.py:78
#: nuitka_build_config/models/__init__.py:17
msgid "Packages whose data files should be included (--include-package-data)"
msgstr "Пакеты, файлы данных которых следует включить (--include-package-data)"

#: nuitka_build_config/generator.py:80
#: nuitka_build_config/models/__init__.py:18
msgid "File patterns to include (--include-data-files)"
msgstr "Шаблоны файлов для включения (--include-data-files)"

#: nuitka_build_config/generator.py:82
#: nuitka_build_config/models/__init__.py:20
msgid "Data directories to include (--include-data-dir)"
msgstr "Каталоги данных для включения (--include-data-dir)"

#: nuitka_build_config/generator.py:84
#: nuitka_build_config/models/__init__.py:22
msgid "File patterns to exclude from data (--noinclude-data-files)"
msgstr "Шаблоны файлов для исключения из данных (--noinclude-data-files)"

#: nuitka_build_config/generator.py:90
msgid "Path to icon file (ICO format)"
msgstr "Путь к файлу иконки (формат ICO)"

#: nuitka_build_config/generator.py:92
msgid "Extract icon from existing EXE file"
msgstr "Извлечь иконку из существующего EXE-файла"

#: nuitka_build_config/generator.py:95
#: nuitka_build_config/models/osparams.py:20
msgid ""
"Windows console mode: 'force' - create a console window (if not started "
"from console), 'disable' - do not create a console (--windows-console-"
"mode)"
msgstr ""
"Режим консоли Windows: 'force' - создать окно консоли (если запущено не из "
"консоли), 'disable' - не создавать консоль (--windows-console-mode)"

#: nuitka_build_config/generator.py:98
#: nuitka_build_config/models/osparams.py:26
msgid "Request administrator privileges via UAC on launch (--windows-uac-admin)"
msgstr "Запрашивать права администратора через UAC при запуске (--windows-uac-admin)"

#: nuitka_build_config/generator.py:100
#: nuitka_build_config/models/osparams.py:31
msgid ""
"Request UAC to launch only from specific folders and remote access "
"(--windows-uac-uiaccess)"
msgstr ""
"Запрашивать UAC для запуска только из определённых папок и удалённого доступа "
"(--windows-uac-uiaccess)"

#: nuitka_build_config/generator.py:106
msgid "Path to icon file for macOS .app bundle (--macos-app-icon)"
msgstr "Путь к файлу иконки для пакета .app в macOS (--macos-app-icon)"

#: nuitka_build_config/generator.py:108
#: nuitka_build_config/models/osparams.py:38
msgid ""
"Create a .app bundle instead of a regular binary. Enables standalone mode"
" (--macos-create-app-bundle)"
msgstr ""
"Создать пакет .app вместо обычного бинарного файла. Включает автономный режим "
"(--macos-create-app-bundle)"

#: nuitka_build_config/generator.py:111
#: nuitka_build_config/models/osparams.py:43
msgid ""
"Application name for macOS signing in 'com.YourCompany.AppName' format. "
"Globally unique identifier for accessing protected APIs (--macos-signed-"
"app-name)"
msgstr ""
"Имя приложения для подписи macOS в формате 'com.YourCompany.AppName'. "
"Глобально уникальный идентификатор для доступа к защищённым API (--macos-signed-"
"app-name)"

#: nuitka_build_config/generator.py:118
msgid "Path to icon file for Linux (--linux-icon)"
msgstr "Путь к файлу иконки для Linux (--linux-icon)"

#: nuitka_build_config/generator.py:124
#: nuitka_build_config/models/__init__.py:26
msgid "Company name in version info (--company-name)"
msgstr "Название компании в информации о версии (--company-name)"

#: nuitka_build_config/generator.py:127
#: nuitka_build_config/models/__init__.py:27
msgid "Product name in version info (--product-name)"
msgstr "Название продукта в информации о версии (--product-name)"

#: nuitka_build_config/generator.py:130
#: nuitka_build_config/models/__init__.py:28
msgid "File version in X.X.X.X format (--file-version)"
msgstr "Версия файла в формате X.X.X.X (--file-version)"

#: nuitka_build_config/generator.py:133
#: nuitka_build_config/models/__init__.py:29
msgid "Copyright text (--copyright)"
msgstr "Текст авторского права (--copyright)"

#: nuitka_build_config/generator.py:136
msgid "Commands"
msgstr "Команды"

#: nuitka_build_config/generator.py:136
msgid "Add commands to run before or after compilation"
msgstr "Добавить команды для выполнения до или после компиляции"

#: nuitka_build_config/generator.py:138
#: nuitka_build_config/models/__init__.py:152
msgid "Commands executed before compilation"
msgstr "Команды, выполняемые перед компиляцией"

#: nuitka_build_config/generator.py:140
#: nuitka_build_config/models/__init__.py:157
msgid "Commands executed after compilation"
msgstr "Команды, выполняемые после компиляции"

#: nuitka_build_config/generator.py:143
msgid "Non-config arguments"
msgstr "Аргументы не из конфигурации"

#: nuitka_build_config/generator.py:144
msgid "Arguments that are not written to the configuration file"
msgstr "Аргументы, которые не записываются в файл конфигурации"

#: nuitka_build_config/generator.py:146
msgid "Path to output file"
msgstr "Путь к выходному файлу"

#: nuitka_build_config/generator.py:148
msgid "Compile the application after generating the configuration file"
msgstr "Скомпилировать приложение после создания файла конфигурации"

#: nuitka_build_config/generator.py:151
msgid "show program's version number and exit"
msgstr "показать версию программы и выйти"

#: nuitka_build_config/generator.py:165
msgid "'main' option is required"
msgstr "Требуется параметр 'main'"

#: nuitka_build_config/generator.py:166
msgid "Use either just --main or just the positional argument"
msgstr "Используйте либо только --main, либо только позиционный аргумент"

#: nuitka_build_config/generator.py:203
msgid "Extra arguments are added to extra_flags"
msgstr "Дополнительные аргументы добавляются в extra_flags"

#: nuitka_build_config/models/__init__.py:52
msgid ""
"Follow all imported modules. In standalone mode defaults to True "
"(--follow-imports)"
msgstr ""
"Следовать за всеми импортированными модулями. В автономном режиме по умолчанию "
"включено (--follow-imports)"

#: nuitka_build_config/models/__init__.py:57
msgid ""
"Follow into the specified modules/packages (--follow-import-to). Example:"
" 'requests', 'numpy'"
msgstr ""
"Следовать в указанные модули/пакеты (--follow-import-to). Пример: "
"'requests', 'numpy'"

#: nuitka_build_config/models/__init__.py:62
msgid ""
"DO NOT follow into the specified modules/packages. Supports patterns, "
"e.g. '*.tests' (--nofollow-import-to)"
msgstr ""
"НЕ следовать в указанные модули/пакеты. Поддерживает шаблоны, "
"например '*.tests' (--nofollow-import-to)"

#: nuitka_build_config/models/__init__.py:67
msgid ""
"List of plugins to enable (--enable-plugins). Example: 'tk-inter', 'anti-"
"bloat'"
msgstr ""
"Список включаемых плагинов (--enable-plugins). Пример: 'tk-inter', 'anti-"
"bloat'"

#: nuitka_build_config/models/__init__.py:72
msgid "List of plugins to disable (--disable-plugins)"
msgstr "Список отключаемых плагинов (--disable-plugins)"

#: nuitka_build_config/models/__init__.py:82
msgid ""
"Follow into standard library modules. Increases compilation time "
"(--follow-stdlib)"
msgstr ""
"Следовать в модули стандартной библиотеки. Увеличивает время компиляции "
"(--follow-stdlib)"

#: nuitka_build_config/models/__init__.py:87
msgid "Windows parameters: console mode, UAC, icon, etc."
msgstr "Параметры Windows: режим консоли, UAC, иконка и т.д."

#: nuitka_build_config/models/__init__.py:92
msgid "macOS parameters: .app bundle creation, signing, version, etc."
msgstr "Параметры macOS: создание пакета .app, подпись, версия и т.д."

#: nuitka_build_config/models/__init__.py:97
msgid "Linux parameters: icon and other settings"
msgstr "Параметры Linux: иконка и другие настройки"

#: nuitka_build_config/models/__init__.py:137
msgid "Additional Nuitka command line flags not described in this model"
msgstr "Дополнительные флаги командной строки Nuitka, не описанные в этой модели"

#: nuitka_build_config/models/__init__.py:142
msgid ""
"Version info for Windows/macOS: company name, product name, file version,"
" copyright"
msgstr ""
"Информация о версии для Windows/macOS: название компании, название продукта, "
"версия файла, авторское право"

#: nuitka_build_config/models/__init__.py:147
msgid "Console output verbosity level: info (default), quiet, verbose"
msgstr "Уровень подробности вывода в консоль: info (по умолчанию), quiet, verbose"

#: nuitka_build_config/models/osparams.py:13
msgid ""
"Path to icon file. On Windows: --windows-icon-from-ico, on macOS: "
"--macos-app-icon, on Linux: --linux-icon"
msgstr ""
"Путь к файлу иконки. В Windows: --windows-icon-from-ico, в macOS: "
"--macos-app-icon, в Linux: --linux-icon"
